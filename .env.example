# Base44 UI
VITE_BASE44_APP_ID=your_app_id
VITE_BASE44_APP_BASE_URL=https://sync-pulse-stream.base44.app

# Local bridge (dev proxy — see vite.config.js)
VITE_BRIDGE_PROXY_PREFIX=/bridge-api

# Direct bridge URL when not using the Vite proxy (production on stream PC)
# VITE_BRIDGE_BASE_URL=http://127.0.0.1:9284

# Optional if BRIDGE_API_TOKEN is set on the bridge
# VITE_BRIDGE_API_TOKEN=

# Resolume local dev proxy
VITE_RESOLUME_PROXY_PREFIX=/resolume-api
