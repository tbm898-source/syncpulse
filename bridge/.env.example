# SyncPulse Local Bridge — copy to .env in this folder

# HTTP bind (loopback only by default)
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=9284

# Optional bearer token for API requests (recommended on shared machines)
# BRIDGE_API_TOKEN=

# CORS: comma-separated browser origins allowed to call the bridge
BRIDGE_CORS_ORIGINS=http://localhost:5173,https://sync-pulse-stream.base44.app,https://www.syncpulsestream.com

# OBS WebSocket (OBS 28+ / protocol v5 default port 4455)
OBS_HOST=127.0.0.1
OBS_PORT=4455
OBS_PASSWORD=

# Mark integration state stale after this many ms without fresh OBS data
BRIDGE_STALE_MS=10000

# Reconnect delay after OBS disconnect
OBS_RECONNECT_MS=3000
