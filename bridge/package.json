{
  "name": "@syncpulse/local-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SyncPulse local bridge — OBS WebSocket and streaming computer integrations",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
